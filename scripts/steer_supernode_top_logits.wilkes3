#!/bin/bash
#!
#! SLURM job script for a NEGATIVE-leaning supernode steering sweep on Wilkes3 (A100).
#! Sweeps the multiplicative steering factor over [-20, +2] in 0.5 steps (default) and
#! records the top-L next-token probability distribution at each magnitude, to see how
#! the top logits shift as a supernode (e.g. the Texas supernode) is steered. Negative
#! steering is the interesting regime here: the clean "Austin" probability is already
#! high, so pushing the supernode down is more informative than pushing it up
#! (cf. Alessandro 2026-06-19).
#!
#! Wraps scripts/sweep_supernode_interventions.py (factor_times_clean_activation steering,
#! i.e. each Texas constituent feature is clamped to magnitude x its clean activation).
#! Based on scripts/sweep_supernode_interventions.wilkes3 (itself from slurms/slurm_submit.wilkes3).
#!

#!#############################################################
#!#### Modify the options in this section as appropriate ######
#!#############################################################

#! sbatch directives begin here ###############################
#! Name of the job:
#SBATCH -J supernode_topL
#! Which project should be charged (NB Wilkes2 projects end in '-GPU'):
#SBATCH -A MPHIL-DIS-SL2-GPU
#! How many whole nodes should be allocated?
#SBATCH --nodes=1
#! How many (MPI) tasks will there be in total?
#! Note probably this should not exceed the total number of GPUs in use.
#SBATCH --ntasks=1
#! Specify the number of GPUs per node (between 1 and 4; must be 4 if nodes>1).
#! Note that the job submission script will enforce no more than 32 cpus per GPU.
#SBATCH --gres=gpu:1
#! How much wallclock time will be required?
#! 45 magnitudes x one forward pass each; single sweep, no bootstrap.
#SBATCH --time=0:30:00
#! What types of email messages do you wish to receive?
#SBATCH --mail-type=NONE
#! Uncomment this to prevent the job from being requeued (e.g. if
#! interrupted by node failure or system downtime):
##SBATCH --no-requeue

#! Do not change:
#SBATCH -p ampere

#! sbatch directives end here (put any additional directives above this line)

#! Notes:
#! Charging is determined by GPU number*walltime.

#! Number of nodes and tasks per node allocated by SLURM (do not change):
numnodes=$SLURM_JOB_NUM_NODES
numtasks=$SLURM_NTASKS
mpi_tasks_per_node=$(echo "$SLURM_TASKS_PER_NODE" | sed -e  's/^\([0-9][0-9]*\).*$/\1/')
#! ############################################################
#! Modify the settings below to specify the application's environment, location
#! and launch method:

#! Optionally modify the environment seen by the application
#! (note that SLURM reproduces the environment at submission irrespective of ~/.bashrc):
. /etc/profile.d/modules.sh                # Leave this line (enables the module command)
module purge                               # Removes all modules still loaded
module load rhel8/default-amp              # REQUIRED - loads the basic environment

#! Insert additional module load commands after this line if needed:

source /home/rd761/miniconda3/bin/activate qwen-sae
export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:$LD_LIBRARY_PATH"

#! Use RDS/HPC storage for Hugging Face cache rather than home.
export HF_HOME="/rds/user/rd761/hpc-work/huggingface"
export HF_HUB_CACHE="/rds/user/rd761/hpc-work/huggingface/hub"

#! Work directory (i.e. where the job will run):
workdir="/home/rd761/mphil-project/llm-biology"

#! Are you using OpenMP (NB this is unrelated to OpenMPI)? If so increase this
#! safe value to no more than 128:
export OMP_NUM_THREADS=1

while [ "$#" -gt 0 ] && [ -z "${1//[[:space:]]/}" ]; do
        shift
done

#! Defaults target the Texas supernode in the Dallas/Texas/Austin graph; override the
#! positional args for any other supernode ("for a given supernode").
GRAPH_JSON="${1:-${GRAPH_JSON:-data/ui_graphs/2026-06-10-15-29-17-fact-the-capital-of-the-state-containing-dallas-i.json}}"
SUPERNODE="${2:-${SUPERNODE:-Texas}}"
#! Negative-leaning sweep: [-20, +2] in 0.5 steps (45 magnitudes). 1 = clean, 0 = ablate.
MAGNITUDES="${MAGNITUDES:--20,-19.5,-19,-18.5,-18,-17.5,-17,-16.5,-16,-15.5,-15,-14.5,-14,-13.5,-13,-12.5,-12,-11.5,-11,-10.5,-10,-9.5,-9,-8.5,-8,-7.5,-7,-6.5,-6,-5.5,-5,-4.5,-4,-3.5,-3,-2.5,-2,-1.5,-1,-0.5,0,0.5,1,1.5,2}"
#! How many top-probability next tokens to record per magnitude (the top-L logits).
TOP_L="${TOP_L:-15}"
OUTPUT_JSON="${OUTPUT_JSON:-}"
EXTRA_ARGS="${EXTRA_ARGS:-}"

if [ -z "$GRAPH_JSON" ] || [ -z "$SUPERNODE" ]; then
        echo "Usage: sbatch scripts/steer_supernode_top_logits.wilkes3 [graph-json] [supernode-label]"
        echo "Defaults: graph=data/ui_graphs/2026-06-10-15-29-17-fact-...-dallas-i.json supernode=Texas"
        echo "Optional env: TOP_L=15 MAGNITUDES='-20,...,2' OUTPUT_JSON=/path/out.json"
        echo "  EXTRA_ARGS='--chat-template'   (any extra flags passed through to the .py)"
        exit 2
fi

#! Full path to application executable:
application="srun"

#! Run options for the application:
options="python -u scripts/sweep_supernode_interventions.py \"$GRAPH_JSON\" \"$SUPERNODE\" --magnitudes=\"$MAGNITUDES\" --top-prob-tokens=\"$TOP_L\" $EXTRA_ARGS"
if [ -n "$OUTPUT_JSON" ]; then
        options="$options --output \"$OUTPUT_JSON\""
fi

#! Number of MPI tasks to be started by the application per node and in total (do not change):
np=$[${numnodes}*${mpi_tasks_per_node}]

#! Choose this for a pure shared-memory OpenMP parallel program on a single node:
#! (OMP_NUM_THREADS threads will be created):
CMD="$application $options"

#! Choose this for a MPI code using OpenMPI:
#CMD="mpirun -npernode $mpi_tasks_per_node -np $np $application $options"


###############################################################
### You should not have to change anything below this line ####
###############################################################

mkdir -p "$workdir/slurm_logs"
cd $workdir
echo -e "Changed directory to `pwd`.\n"

JOBID=$SLURM_JOB_ID

echo -e "JobID: $JOBID\n======"
echo "Time: `date`"
echo "Running on master node: `hostname`"
echo "Current directory: `pwd`"
echo "Python: `which python`"
python --version
nvidia-smi

if [ "$SLURM_JOB_NODELIST" ]; then
        #! Create a machine file:
        export NODEFILE=`generate_pbs_nodefile`
        cat $NODEFILE | uniq > "slurm_logs/machine.file.$JOBID"
        echo -e "\nNodes allocated:\n================"
        echo `cat "slurm_logs/machine.file.$JOBID" | sed -e 's/\..*$//g'`
fi

echo -e "\nnumtasks=$numtasks, numnodes=$numnodes, mpi_tasks_per_node=$mpi_tasks_per_node (OMP_NUM_THREADS=$OMP_NUM_THREADS)"

echo -e "\nExecuting command:\n==================\n$CMD\n"

eval $CMD
